# ServiceSync Environment Configuration
# These variables are required to run the application on a custom server.
# Replace all example values with your own credentials.

# -------------------------------
# DATABASE (stores all submissions)
# -------------------------------
# Example: PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/servicesync_db

# -------------------------------
# EMAIL SERVICE (optional - for notifications)
# -------------------------------
# Example: Gmail SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=school-email@domain.com
SMTP_PASS=your-app-password

# -------------------------------
# FILE STORAGE (stores uploaded PDFs/images)
# -------------------------------
# Example: cloud storage provider credentials (AWS S3, Google Cloud, etc.)

STORAGE_PROVIDER=s3
STORAGE_BUCKET=servicesync-uploads
STORAGE_REGION=us-east-1

# Access credentials (example format)
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key

# -------------------------------
# APP CONFIGURATION
# -------------------------------
# Base URL of the deployed app
BASE_URL=https://your-domain.com

# Environment mode
NODE_ENV=production