# ServiceSync Environment Configuration
# Copy this file to .env and fill in all required values before running.

# ================================
# REQUIRED — App will crash without these
# ================================

# Secret used to sign session cookies. Use a long random string (32+ characters).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-long-random-secret-here

# Admin login credentials for the review dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password

# ================================
# DATABASE (stores all submission records)
# ================================
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/servicesync_db

# ================================
# FILE STORAGE — Google Cloud Storage
# Required for storing uploaded PDFs and images from students
# ================================
# Your GCP project ID
GCS_PROJECT_ID=your-project-id

# Service account credentials (from a downloaded JSON key file)
GCS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The private key from the JSON key file.
# IMPORTANT: Replace literal newlines in the key with \n so it fits on one line.
GCS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n

# The name of the GCS bucket where uploads will be stored
STORAGE_BUCKET=your-bucket-name

# ================================
# AI SCANNING — OpenAI
# Used to validate that uploaded forms are the correct template and legible.
# If not set, submissions will be accepted without AI validation.
# ================================
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# ================================
# EMAIL — SMTP (optional)
# If not configured, status notification emails are silently skipped.
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=school-email@domain.com
SMTP_PASS=your-app-password
# Defaults to SMTP_USER if not set
SMTP_FROM=noreply@yourdomain.com

# ================================
# APP
# ================================
BASE_URL=https://your-domain.com
NODE_ENV=production